    <!-- http://purl.obolibrary.org/obo/NCIT_C54627 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C54627">
        <owl:equivalentClass rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Experience"/>
        <rdfs:comment>External NCIT reference for the Experience concept.</rdfs:comment>
        <rdfs:label>ExperienceNcit</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/NCIT_C75561 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C75561">
        <owl:equivalentClass rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Student"/>
        <rdfs:comment>External NCIT reference for the Student concept.</rdfs:comment>
        <rdfs:label>StudentNcit</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/NCIT_C84385 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/NCIT_C84385">
        <owl:equivalentClass rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Profile"/>
        <rdfs:comment>External NCIT reference for the Profile concept.</rdfs:comment>
        <rdfs:label>ProfileNcit</rdfs:label>
    </owl:Class>
    


    <!-- http://schema.org/EducationalOccupationalCredential -->

    <owl:Class rdf:about="http://schema.org/EducationalOccupationalCredential">
        <owl:equivalentClass rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Education"/>
        <rdfs:comment>Schema.org class equivalent to Education in this ontology.</rdfs:comment>
        <rdfs:label>EducationalOccupationalCredential</rdfs:label>
    </owl:Class>
    


    <!-- http://schema.org/Organization -->

    <owl:Class rdf:about="http://schema.org/Organization">
        <owl:equivalentClass rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Organization"/>
        <rdfs:comment>Schema.org class equivalent to Organization in this ontology.</rdfs:comment>
        <rdfs:label>SchemaOrganization</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Activity -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Activity">
        <rdfs:comment>An action performed by a user on the platform such as a post, comment, repost or reaction.</rdfs:comment>
        <rdfs:label>Activity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Certification -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Certification">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Education"/>
        <rdfs:comment>A formal recognition awarded after completing a course or examination.</rdfs:comment>
        <rdfs:label>Certification</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Comment -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Comment">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Activity"/>
        <rdfs:comment>A textual response made by a user on a post.</rdfs:comment>
        <rdfs:label>Comment</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Connection -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Connection">
        <rdfs:comment>A link representing a relationship between two users on the platform.</rdfs:comment>
        <rdfs:label>Connection</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#ContractJob -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#ContractJob">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Job"/>
        <rdfs:comment>A job offered on a contractual basis for a fixed time period.</rdfs:comment>
        <rdfs:label>ContractJob</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Degree -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Degree">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Education"/>
        <rdfs:comment>A formal academic qualification awarded by a university.</rdfs:comment>
        <rdfs:label>Degree</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Diploma -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Diploma">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Education"/>
        <rdfs:comment>An educational qualification awarded for completion of a course shorter than a degree.</rdfs:comment>
        <rdfs:label>Diploma</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Education -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Education">
        <rdfs:comment>An academic credential or qualification held by a user.</rdfs:comment>
        <rdfs:label>Education</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Experience -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Experience">
        <rdfs:comment>Work or internship experience associated with a user.</rdfs:comment>
        <rdfs:label>Experience</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#GraduateStudent -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#GraduateStudent">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Student"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://schema.org/hasCredential"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Degree"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#UnderGraduateStudent"/>
        <rdfs:comment>A student currently pursuing a graduate-level program.</rdfs:comment>
        <rdfs:label>GraduateStudent</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Internship -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Internship">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Job"/>
        <rdfs:comment>A short-term job typically taken by students for practical experience.</rdfs:comment>
        <rdfs:label>Internship</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#InternshipExperience -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#InternshipExperience">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Experience"/>
        <rdfs:comment>Experience obtained by working as an intern.</rdfs:comment>
        <rdfs:label>InternshipExperience</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Job -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Job">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#requiresSkill"/>
                <owl:allValuesFrom rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Skill"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A job posting offered by an organization on the platform.</rdfs:comment>
        <rdfs:label>Job</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#JobApplication -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#JobApplication">
        <rdfs:comment>A formal application submitted by a user for a job.</rdfs:comment>
        <rdfs:label>JobApplication</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#OnSiteJob -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#OnSiteJob">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Job"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#RemoteJob"/>
        <rdfs:comment>A job requiring physical presence at the workplace.</rdfs:comment>
        <rdfs:label>OnSiteJob</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Organization -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Organization">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:comment>A company, institution or entity that hires users or is affiliated with users.</rdfs:comment>
        <rdfs:label>Organization</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#PaidInternship -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#PaidInternship">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Internship"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#UnPaidInternship"/>
        <rdfs:comment>An internship in which the intern receives monetary compensation.</rdfs:comment>
        <rdfs:label>PaidInternship</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Post -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Post">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Activity"/>
        <rdfs:comment>A piece of content published by a user on the platform.</rdfs:comment>
        <rdfs:label>Post</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#PrivateOrganization -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#PrivateOrganization">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Organization"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#PublicOrganization"/>
        <rdfs:comment>A privately owned organization.</rdfs:comment>
        <rdfs:label>PrivateOrganization</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Professional -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Professional">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:comment>A user who is employed and active in their professional career.</rdfs:comment>
        <rdfs:label>Professional</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#ProfessionalProfile -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#ProfessionalProfile">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Profile"/>
        <rdfs:comment>A profile that emphasizes professional information and work history.</rdfs:comment>
        <rdfs:label>ProfessionalProfile</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Profile -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Profile">
        <rdfs:comment>A user&apos;s public-facing profile on the platform.</rdfs:comment>
        <rdfs:label>Profile</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#PublicOrganization -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#PublicOrganization">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Organization"/>
        <rdfs:comment>A publicly owned or government organization.</rdfs:comment>
        <rdfs:label>PublicOrganization</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#PublicProfile -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#PublicProfile">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Profile"/>
        <rdfs:comment>A profile that is visible to all users on the platform.</rdfs:comment>
        <rdfs:label>PublicProfile</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Reaction -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Reaction">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Activity"/>
        <rdfs:comment>An emotional response left by a user on a post or comment.</rdfs:comment>
        <rdfs:label>Reaction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Recruiter -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Recruiter">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:comment>A user whose role is to identify and hire candidates for jobs.</rdfs:comment>
        <rdfs:label>Recruiter</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#RemoteJob -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#RemoteJob">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Job"/>
        <rdfs:comment>A job that can be performed remotely without physical presence.</rdfs:comment>
        <rdfs:label>RemoteJob</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Repost -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Repost">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Activity"/>
        <rdfs:comment>An activity in which a user shares another user&apos;s post.</rdfs:comment>
        <rdfs:label>Repost</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Skill -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Skill">
        <rdfs:comment>A capability possessed by a user or required by a job.</rdfs:comment>
        <rdfs:label>Skill</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#SoftSkill -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#SoftSkill">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Skill"/>
        <rdfs:comment>A non-technical interpersonal capability such as communication or leadership.</rdfs:comment>
        <rdfs:label>SoftSkill</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Student -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Student">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:comment>A user currently enrolled in an academic program.</rdfs:comment>
        <rdfs:label>Student</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#TechnicalSkill -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#TechnicalSkill">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Skill"/>
        <rdfs:comment>A technical capability such as a programming language or framework.</rdfs:comment>
        <rdfs:label>TechnicalSkill</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#UnPaidInternship -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#UnPaidInternship">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Internship"/>
        <rdfs:comment>An internship in which the intern does not receive monetary compensation.</rdfs:comment>
        <rdfs:label>UnPaidInternship</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#UnderGraduateStudent -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#UnderGraduateStudent">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Student"/>
        <rdfs:comment>A student currently pursuing an undergraduate-level program.</rdfs:comment>
        <rdfs:label>UnderGraduateStudent</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User">
        <rdfs:comment>A registered person or entity on the platform.</rdfs:comment>
        <rdfs:label>User</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#WorkExperience -->

    <owl:Class rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#WorkExperience">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Experience"/>
        <rdfs:comment>Experience obtained through regular employment.</rdfs:comment>
        <rdfs:label>WorkExperience</rdfs:label>
    </owl:Class>
    


