<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#"
     xml:base="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:ccf="http://purl.org/ccf/"
     xmlns:ddd="http://purl.obolibrary.org/obo/gsso.owl#"
     xmlns:hum="https://purl.humanatlas.io/vocab/ccf#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:ppp="http://purl.uniprot.org/core/"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:tgt="http://purl.obolibrary.org/obo/fbcv.owl#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:agro="http://snomed.info/sct/9000000000002070081231#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:ncit="http://purl.obolibrary.org/obo/ncit.owl#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:repro="https://w3id.org/reproduceme#"
     xmlns:schema="http://schema.org/"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21">
        <dcterms:creator>Obaid Ur Rahman Zia</dcterms:creator>
        <dcterms:description>An ontology modeling users, profiles, jobs, organizations, skills, education and job applications in a professional networking platform.</dcterms:description>
        <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <dcterms:rightsHolder>University of Sargodha</dcterms:rightsHolder>
        <dcterms:title>Professional Networking and Recruitment Ontology</dcterms:title>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/terms/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/rightsHolder -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/rightsHolder"/>
    


    <!-- http://purl.org/dc/terms/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://schema.org/hasCredential -->

    <owl:ObjectProperty rdf:about="http://schema.org/hasCredential">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#credentialOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Education"/>
        <rdfs:comment>Relates a user to an educational credential they hold.</rdfs:comment>
        <rdfs:label>hasCredential</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://schema.org/knows -->

    <owl:ObjectProperty rdf:about="http://schema.org/knows">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isKnownBy"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:comment>Relates one user to another user they know.</rdfs:comment>
        <rdfs:label>knows</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://schema.org/mentions -->

    <owl:ObjectProperty rdf:about="http://schema.org/mentions">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isMentionedIn"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Activity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:comment>Relates an activity to a user mentioned in it.</rdfs:comment>
        <rdfs:label>mentions</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://schema.org/skills -->

    <owl:ObjectProperty rdf:about="http://schema.org/skills">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isSkillOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Skill"/>
        <rdfs:comment>Relates a user to a skill they possess.</rdfs:comment>
        <rdfs:label>skills</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://schema.org/worksFor -->

    <owl:ObjectProperty rdf:about="http://schema.org/worksFor">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#employsExperience"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Experience"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Organization"/>
        <rdfs:comment>Relates an experience to the organization where it was acquired.</rdfs:comment>
        <rdfs:label>worksFor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#applicationForJob -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#applicationForJob">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hasJobApplication"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#JobApplication"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Job"/>
        <rdfs:comment>Relates a job application to the job it targets.</rdfs:comment>
        <rdfs:label>applicationForJob</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#appliesFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#appliesFor">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hasApplicant"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#JobApplication"/>
        <rdfs:comment>Relates a user to a job application they have submitted.</rdfs:comment>
        <rdfs:label>appliesFor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#associatedWithUser -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#associatedWithUser">
        <owl:inverseOf rdf:resource="http://www.w3.org/ns/prov#wasAssociatedWith"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Activity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:comment>Relates an activity to a user it was associated with.</rdfs:comment>
        <rdfs:label>associatedWithUser</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#citedInApplication -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#citedInApplication">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#citesExperience"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Experience"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#JobApplication"/>
        <rdfs:comment>Relates an experience to a job application that cites it.</rdfs:comment>
        <rdfs:label>citedInApplication</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#citesExperience -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#citesExperience">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#JobApplication"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Experience"/>
        <rdfs:comment>Relates a job application to an experience cited in it.</rdfs:comment>
        <rdfs:label>citesExperience</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#credentialOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#credentialOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Education"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:comment>Relates an educational credential to the user who holds it.</rdfs:comment>
        <rdfs:label>credentialOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#employsExperience -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#employsExperience">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Organization"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Experience"/>
        <rdfs:comment>Relates an organization to an experience that was acquired there.</rdfs:comment>
        <rdfs:label>employsExperience</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#experienceOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#experienceOf">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hasExperience"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Experience"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:comment>Relates an experience to the user who holds it.</rdfs:comment>
        <rdfs:label>experienceOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hasAffiliatedUser -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hasAffiliatedUser">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isAffiliatedWith"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Organization"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:comment>Relates an organization to a user affiliated with it.</rdfs:comment>
        <rdfs:label>hasAffiliatedUser</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hasApplicant -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hasApplicant">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#JobApplication"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:comment>Relates a job application to the user who submitted it.</rdfs:comment>
        <rdfs:label>hasApplicant</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hasConnections -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hasConnections">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isConnectionOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Connection"/>
        <rdfs:comment>Relates a user to their connections.</rdfs:comment>
        <rdfs:label>hasConnections</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hasExperience -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hasExperience">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Experience"/>
        <rdfs:comment>Relates a user to their experiences.</rdfs:comment>
        <rdfs:label>hasExperience</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hasJobApplication -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hasJobApplication">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Job"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#JobApplication"/>
        <rdfs:comment>Relates a job to a job application submitted for it.</rdfs:comment>
        <rdfs:label>hasJobApplication</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hasProfile -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hasProfile">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isProfileOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Profile"/>
        <rdfs:comment>Relates a user to their profile.</rdfs:comment>
        <rdfs:label>hasProfile</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hiresFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hiresFor">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hiringOrganization"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Organization"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Job"/>
        <rdfs:comment>Relates an organization to a job it is hiring for.</rdfs:comment>
        <rdfs:label>hiresFor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hiringOrganization -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#hiringOrganization">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Job"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Organization"/>
        <rdfs:comment>Relates a job to the organization that is hiring.</rdfs:comment>
        <rdfs:label>hiringOrganization</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isAffiliatedWith -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isAffiliatedWith">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Organization"/>
        <rdfs:comment>Relates a user to an organization they are affiliated with.</rdfs:comment>
        <rdfs:label>isAffiliatedWith</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isConnectionOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isConnectionOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Connection"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:comment>Relates a connection to the user it belongs to.</rdfs:comment>
        <rdfs:label>isConnectionOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isKnownBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isKnownBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:comment>Inverse of knows: indicates that the subject is known by the object user.</rdfs:comment>
        <rdfs:label>isKnownBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isMentionedIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isMentionedIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Activity"/>
        <rdfs:comment>Relates a user to an activity in which they are mentioned.</rdfs:comment>
        <rdfs:label>isMentionedIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isProfileOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isProfileOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Profile"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:comment>Relates a profile to the user who owns it.</rdfs:comment>
        <rdfs:label>isProfileOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isRequiredBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isRequiredBy">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#requiresSkill"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Skill"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Job"/>
        <rdfs:comment>Relates a skill to a job that requires it.</rdfs:comment>
        <rdfs:label>isRequiredBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isSkillOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#isSkillOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Skill"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#User"/>
        <rdfs:comment>Relates a skill to a user who possesses it.</rdfs:comment>
        <rdfs:label>isSkillOf</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#managedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#managedBy">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#manages"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Job"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Recruiter"/>
        <rdfs:comment>Relates a job to the recruiter who manages it.</rdfs:comment>
        <rdfs:label>managedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#manages -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#manages">
