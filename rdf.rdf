    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Ali -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Ali">
        <rdf:type rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#GraduateStudent"/>
        <schema:hasCredential rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#AliDegree"/>
        <schema:knows rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Bilal"/>
        <schema:knows rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#Sara"/>
        <schema:skills rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#MLSkill"/>
        <schema:skills rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#PythonSkill"/>
        <schema:skills rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#SQLSkill"/>
        <appliesFor rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#AliApplication"/>
        <hasExperience rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#AliExperience"/>
        <hasProfile rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#AliProfile"/>
        <isAffiliatedWith rdf:resource="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#NUST"/>
        <ccf:age rdf:datatype="http://www.w3.org/2001/XMLSchema#int">23</ccf:age>
        <schema:email>ali.hassan@example.com</schema:email>
        <address>Sargodha, Pakistan</address>
        <schemaName>Ali Hassan</schemaName>
        <foaf:gender>Male</foaf:gender>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#AliApplication -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/munib/ontologies/2026/3/untitled-ontology-21#AliApplication">
